    <definition name="member/login" extends="layout-default">
        <put-attribute name="content" value="/WEB-INF/views/member/login.jsp" />
    </definition>

    <!-- 에러 페이지 -->
    <definition name="error/500" extends="layout-default">
        <put-attribute name="content" value="/WEB-INF/views/error/500.jsp" />
    </definition>
    <definition name="error/503" extends="layout-default">
        <put-attribute name="content" value="/WEB-INF/views/error/503.jsp" />
