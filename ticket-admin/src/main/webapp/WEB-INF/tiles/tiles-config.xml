        <put-attribute name="footer"  value="/WEB-INF/views/layout/footer.jsp" />
    </definition>

    <!-- 백오피스 레이아웃 -->
    <definition name="layout-backoffice" template="/WEB-INF/views/layout/backoffice-layout.jsp">
